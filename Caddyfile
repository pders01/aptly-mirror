{
	email {$ACME_EMAIL}
	servers {
		protocols h1 h2 h3
		# Trust Dokploy/Traefik (or any local reverse proxy) so X-Forwarded-For
		# yields real client IP for the allowlist below. Drop this stanza if
		# Caddy is internet-facing with no proxy in front.
		trusted_proxies static private_ranges
	}
}

{$APT_DOMAIN} {
	# IP allowlist. Space-separated CIDRs in $ALLOWED_IPS, e.g.
	#   ALLOWED_IPS="1.2.3.4/32 10.0.0.0/24 2001:db8::/32"
	# ACME http-01 challenge is always allowed so cert renewal works.
	@denied {
		not {
			remote_ip {$ALLOWED_IPS}
		}
		not {
			path /.well-known/acme-challenge/*
		}
	}
	respond @denied "Forbidden" 403

	root * /srv/apt
	encode zstd gzip
	file_server browse

	@dotfiles {
		path_regexp dotfile ^/\.(?!well-known)
	}
	respond @dotfiles 404

	@debs {
		path *.deb *.udeb
	}
	header @debs Cache-Control "public, max-age=31536000, immutable"

	@release {
		path_regexp release /(InRelease|Release|Release\.gpg|Packages(\.gz|\.xz)?|Sources(\.gz|\.xz)?)$
	}
	header @release Cache-Control "no-cache"

	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Content-Type-Options "nosniff"
		Referrer-Policy "no-referrer"
		-Server
	}

	log {
		output stdout
		format console
	}
}
